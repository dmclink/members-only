<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ClubHouse - User Settings</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
        <h1><%= username %>'s Settings</h1>

        <h2>Password</h2>
        <form action="/user/new-password" method="POST">
            <label for="previous_password">Previous Password:</label>
            <input id="previous_password" type="password" name="previous_password" value="">

            <label for="current_password">New Password:</label>
            <input id="current_password" type="password" name="current_password" value="">

            <label for="confirm_password">Confirm Password:</label>
            <input id="confirm_password" type="password" name="confirm_password" value="">

            <div class="span-2">
                <button type="submit">Change Password</button>
            </div>
                
        </form>
        <% if (typeof passwordError !== 'undefined') { %>
          <p><%= passwordError %></p>
        <% } %>

        <h2>Club Code</h2>
        <form action="/user/new-club-code" method="POST">
            <label for="club_code">New Club Code:</label>
            <input id="club_code" type="text" name="club_code" value="<%= club_code %>" maxlength="255">

            <div class="span-2">
              <button type="submit">Change Club Code</button>
            </div>
        </form>

        <p>Back to <a href="/home">main page</a></p>
    
</body>
</html>
